{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "org-GUI",
  "mainBinaryName": "org-GUI",
  "version": "0.2.33",
  "identifier": "com.zhuojianlook.orggui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "org-GUI",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/zhuojianlook/org-GUI/updater/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCM0VFQkMwQTczQzk2QTUKUldTbGxqeW53T3MrSzRUL2RNR2JVWnpHcEhOQUlIaCttektvMUxydGxzU3pmRy9XY01pSVN5SUIK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/org-gui-bridge.el"]
  }
}
