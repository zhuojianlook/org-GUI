# First-party Google OAuth client for the bundled "Sign in with Google" flow.
# Copy this file to `.env.local` (which is gitignored) and fill in the values
# from your Google Cloud "Desktop app" OAuth client. Then `npm run build` /
# `npx tauri build` will bake them in and the Google Calendar panel shows the
# one-click sign-in button instead of asking for credentials.
#
# In CI these come from the GitHub Actions repo secrets GOOGLE_CLIENT_ID /
# GOOGLE_CLIENT_SECRET (mapped to these VITE_ vars in .github/workflows/release.yml).
#
# Leave empty / unset to fall back to the bring-your-own-credentials form.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=
